{
  "name": "the-obsolete-human",
  "version": "0.1.0",
  "private": true,
  "description": "A carbon footprint awareness platform that visualizes personal emissions as a museum exhibit from the year 3026",
  "keywords": [
    "carbon",
    "footprint",
    "climate",
    "environment",
    "sustainability",
    "emissions",
    "nextjs",
    "react"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "dompurify": "^3.2.6",
    "next": "14.2.29",
    "react": "^18",
    "react-dom": "^18",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4.5.2",
    "eslint": "^8",
    "eslint-config-next": "14.2.29",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-security": "^3.0.1",
    "jsdom": "^26.1.0",
    "postcss": "^8",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^3.2.3"
  }
}
